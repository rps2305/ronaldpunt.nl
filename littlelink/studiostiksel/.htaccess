<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self' https://matomo.puntuale.nl; font-src 'self'; form-action 'self' https://submit.jotform.com; frame-src https://submit.jotform.com; frame-ancestors 'none'; img-src 'self' data: https://matomo.puntuale.nl; manifest-src 'self'; object-src 'none'; script-src 'self' https://matomo.puntuale.nl 'sha256-FXbP/cKN1z5oiCNMPKNZ0pBhz6f2XDBtuPXkwwFEtUQ=' 'sha256-m7ecIZaEQnS2lB97AqeKRxQtsLOrpAxYR6deTEGb0bE='; style-src 'self'; upgrade-insecure-requests; block-all-mixed-content;"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set X-Frame-Options "DENY"
</IfModule>
